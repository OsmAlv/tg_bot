TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
HTTP_TIMEOUT_SECONDS=20
KRW_PER_USD=
FIXED_USD_UZS=
ADMIN_PANEL_KEY=spidoznie_kozyavki
MANAGER_CHAT_URL=https://t.me/avalon_support_manager
AUTOPOST_CHANNEL=@avalon_motors_uz
AUTO_SCAN_CONFIG_PATH=autopost_filters.json
# Railway persistent volume path (recommended). Local fallback can be data/autopost_seen.json
AUTO_SCAN_STATE_PATH=/data/autopost_seen.json
# Leave empty to run once (recommended for cron). Set minutes for loop mode.
AUTO_SCAN_INTERVAL_MINUTES=
AUTO_SCAN_DISABLE_PLAYWRIGHT=1
PLAYWRIGHT_BROWSERS_PATH=/app/.playwright